# Resend API key — required for the contact form.
# Sign up at https://resend.com, create an API key, paste below.
RESEND_API_KEY=re_your_key_here

# Where contact-form messages are delivered (defaults to jonathan.zambrano.k@gmail.com).
CONTACT_TO_EMAIL=jonathan.zambrano.k@gmail.com

# Sender address. For testing use Resend's shared address "onboarding@resend.dev".
# For production, verify your own domain in Resend and use e.g. "contact@jonthz.dev".
CONTACT_FROM_EMAIL=onboarding@resend.dev
